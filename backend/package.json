{
  "name": "backend",
  "version": "1.0.0",
  "description": "Quirofisicos Rocha appointment backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "sequelize-cli db:migrate --config src/config/config.js --migrations-path migrations --models-path src/models",
    "db:seed": "sequelize-cli db:seed:all --config src/config/config.js --seeders-path seeders --models-path src/models",
    "db:reset": "sequelize-cli db:migrate:undo:all --config src/config/config.js --migrations-path migrations --models-path src/models && npm run db:migrate && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  }
}
